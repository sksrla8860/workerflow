{
  "name": "worker-flow",
  "productName": "WorkerFlow",
  "version": "2.0.6",
  "description": "Desktop Timeline Widget",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:secure": "node build-secure.js && electron-builder"
  },
  "author": "shinetic",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "fs-extra": "^11.3.4",
    "javascript-obfuscator": "^5.4.1"
  },
  "build": {
    "appId": "com.shinetic.workerflow",
    "productName": "WorkerFlow",
    "directories": {
      "app": "release-src"
    },
    "files": [
      "**/*",
      "!dist",
      "!dist.bak",
      "!.git",
      "!token.json",
      "!node_modules/.cache"
    ],
    "win": {
      "target": [
        "appx"
      ],
      "icon": "build/icon.png"
    },
    "extraResources": [
      {
        "from": "icon.ico",
        "to": "icon.ico"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WorkerFlow",
      "runAfterFinish": true
    },
    "appx": {
      "applicationId": "WorkerFlow",
      "identityName": "shinetic.workerflow",
      "publisher": "CN=23DB3E70-433B-4176-AB45-5B57DA2514FB",
      "publisherDisplayName": "shinetic",
      "backgroundColor": "#03D8A7",
      "addAutoLaunchExtension": true,
      "languages": [
        "en-US",
        "ko-KR",
        "ja-JP",
        "zh-CN",
        "es-ES"
      ]
    }
  }
}